{
  "name": "evalify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm test -- --passWithNoTests && next dev",
    "dev:skip-tests": "next dev",
    "build": "npm test -- --passWithNoTests && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --passWithNoTests --ci --coverage",
    "dev:full": "concurrently \"next dev\" \"jest --watch --passWithNoTests\"",
    "dev:watch": "jest --watch --passWithNoTests",
    "dev:server": "next dev",
    "vercel-install": "npm install --legacy-peer-deps",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm test && playwright test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.6",
    "@ai-sdk/google": "^1.0.6",
    "@ai-sdk/groq": "^1.0.6",
    "@ai-sdk/openai": "^1.3.0",
    "@ai-sdk/openai-compatible": "^0.2.0",
    "@ai-sdk/react": "^1.0.6",
    "@tailwindcss/typography": "^0.5.15",
    "ai": "^4.3.0",
    "next": "16.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "zod": "^3.23.8",
    "@vercel/analytics": "^1.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.2.0",
    "typescript": "^5",
    "concurrently": "^8.2.2",
    "@playwright/test": "^1.42.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}