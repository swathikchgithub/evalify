# ─────────────────────────────────────────────────────────────
# Evalify — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Public LLM API Keys (for Compare tab) ────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GOOGLE_GENERATIVE_AI_API_KEY=AI...

# ── Custom Endpoint API Keys ──────────────────────────────────
# These are referenced by apiKeyEnvVar in config/endpoints.ts
# Leave empty if your endpoint uses VPN/network auth only

CUSTOM_ENDPOINT_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
KSERVE_API_KEY=
